# Cross-Account Configuration
# Copy this file to .env.local and fill in your values

# The IAM role ARN in the target account that allows cross-account access
CROSS_ACCOUNT_ROLE_ARN=arn:aws:iam::123456789012:role/CrossAccountS3GlacierRole

# The S3 bucket name in the target account
CROSS_ACCOUNT_BUCKET=my-glacier-bucket

# The AWS region where the bucket is located
CROSS_ACCOUNT_REGION=us-east-1
